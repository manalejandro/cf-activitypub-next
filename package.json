{
  "name": "cf-activitypub",
  "version": "1.0.2",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/manalejandro/cf-activitypub-next.git"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "eslint",
    "preview": "opennextjs-cloudflare build && wrangler dev",
    "deploy": "opennextjs-cloudflare build && wrangler deploy",
    "db:migrate": "wrangler d1 execute cf-activitypub --remote --file=lib/db/schema.sql",
    "db:drop": "wrangler d1 execute cf-activitypub --remote --file=lib/db/drop.sql"
  },
  "dependencies": {
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250409.0",
    "@opennextjs/cloudflare": "^1.3.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.10.0"
  }
}
